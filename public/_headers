# Cloudflare Pages custom headers (https://developers.cloudflare.com/pages/configuration/headers/)
#
# NOTE: keep the CSP in sync with the integrations actually enabled.
# - Enabling Cloudflare Web Analytics (NEXT_PUBLIC_CF_ANALYTICS_TOKEN) also
#   needs: script-src + connect-src to allow static.cloudflareinsights.com
#   and cloudflareinsights.com.
# - Enabling Google AdSense (NEXT_PUBLIC_ADSENSE_CLIENT) needs the official
#   Google list of hosts (pagead2.googlesyndication.com etc.) added to
#   script-src, frame-src, img-src and connect-src.
# Make those changes when the integrations are switched on, not before.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
