{
  // CoolPDF is a fully static site (Next.js `output: 'export'` → ./out).
  // This config tells Wrangler to deploy ./out as static assets ONLY, so the
  // Workers Builds pipeline never attempts the OpenNext full-stack migration
  // (which requires a Node server build and fails on static exports).
  "name": "coolpdf",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./out",
    // Site is pre-rendered HTML (not an SPA): unknown paths get the 404 page.
    "not_found_handling": "404-page"
  }
}
