# CoolPDF environment variables (all optional — sensible defaults are baked into the code).
# Copy this file to .env.local for local overrides.

# Canonical site URL used for metadata, canonical links, hreflang and sitemap.
# Default: https://getcoolpdf.com
NEXT_PUBLIC_SITE_URL=https://getcoolpdf.com

# GitHub organization / repository URL shown in the footer and About page.
# Default: https://github.com/coolpdf
NEXT_PUBLIC_GITHUB_URL=https://github.com/coolpdf

# Cloudflare Web Analytics token. When set, the (cookieless) beacon script is
# injected into the root layout. Leave empty to disable analytics.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Google AdSense client id (e.g. ca-pub-xxxxxxxxxxxxxxxx). When set, the
# AdBanner component can render ad units. Leave empty to disable ads.
NEXT_PUBLIC_ADSENSE_CLIENT=
